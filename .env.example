# Database — local Docker Postgres
POSTGRES_USER=delorean
POSTGRES_PASSWORD=delorean
POSTGRES_DB=delorean
# From host: postgresql://delorean:delorean@localhost:5433/delorean
# From backend container: postgresql://delorean:delorean@db:5432/delorean
DATABASE_URL=postgresql://delorean:delorean@db:5432/delorean

# External APIs (Phase 2 — placeholders for now)
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# Auth (Phase 1 — auth-login feature)
NEXTAUTH_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Backend API auth (backend-auth feature)
# Shared secret the backend requires on protected routes (Authorization: Bearer <value>).
# The Next.js proxy attaches this server-to-server; it never reaches the browser.
# Generate with `openssl rand -base64 32`. MUST be identical to the frontend's
# BACKEND_API_SECRET. In prod, set the same value on both Render (backend) and Vercel (frontend).
BACKEND_API_SECRET=

# CORS — backend accepts requests from this origin (defaults to localhost:3000 if unset)
# Set to the production Vercel URL on Render: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000
