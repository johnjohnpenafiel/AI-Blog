# Database — local Docker Postgres
POSTGRES_USER=delorean
POSTGRES_PASSWORD=delorean
POSTGRES_DB=delorean
# From host: postgresql://delorean:delorean@localhost:5433/delorean
# From backend container: postgresql://delorean:delorean@db:5432/delorean
DATABASE_URL=postgresql://delorean:delorean@db:5432/delorean

# External APIs (Phase 2 — placeholders for now)
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# Auth (Phase 1 — auth-login feature)
NEXTAUTH_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=
