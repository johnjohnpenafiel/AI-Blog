# NextAuth — generate with `openssl rand -base64 32`
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Backend URL used by NextAuth's authorize() callback (server-side).
# Container-internal URL when running NextAuth inside Docker; localhost when running `npm run dev` on host.
BACKEND_URL=http://localhost:8000

# Shared secret the /api/* proxy attaches when calling the backend's protected
# routes (Authorization: Bearer <value>). Server-side only — never exposed to the
# browser. MUST be identical to the backend's BACKEND_API_SECRET.
BACKEND_API_SECRET=
